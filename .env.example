# === OpenCode Web Orchestrator ===

# WORKSPACE_ROOT: để trống nếu muốn dùng folder bất kỳ
# Nếu set, chỉ cho phép repo path nằm trong thư mục này
# WORKSPACE_ROOT=C:\Users\You\repos

# === OpenCode Provider Config ===

# --- OpenAI (cho planner, reviewer) ---
OPENAI_API_KEY=sk-...

# --- Ollama (cho coder) ---
# Cần chạy Ollama service trước: https://ollama.com
# Pull model: ollama pull qwen3-coder:9b
# OLLAMA_HOST=http://localhost:11434

# --- Hoặc dùng các provider khác ---
# ANTHROPIC_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GITHUB_API_KEY=...
